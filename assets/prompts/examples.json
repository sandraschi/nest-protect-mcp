  "workflows": [
    {
      "name": "Daily Safety Check",
      "description": "Routine daily monitoring workflow",
      "steps": [
        {
          "tool": "list_devices",
          "purpose": "Get overview of all devices"
        },
        {
          "tool": "get_device_events",
          "purpose": "Check for any unusual activity",
          "parameters": {"limit": 10}
        }
      ]
    },
    {
      "name": "Monthly Maintenance",
      "description": "Complete monthly device maintenance",
      "steps": [
        {
          "tool": "list_devices",
          "purpose": "Identify all devices needing testing"
        },
        {
          "tool": "run_safety_check",
          "purpose": "Test each device functionality",
          "repeat": "for_each_device"
        },
        {
          "tool": "get_device_events",
          "purpose": "Review test results and activity",
          "parameters": {"limit": 20}
        }
      ]
    },
    {
      "name": "Emergency Response",
      "description": "Coordinated emergency alarm response",
      "steps": [
        {
          "tool": "get_device_status",
          "purpose": "Confirm alarm details and device status"
        },
        {
          "tool": "hush_alarm",
          "purpose": "Silence alarm to reduce panic",
          "parameters": {"duration_seconds": 300}
        },
        {
          "tool": "get_device_events",
          "purpose": "Document incident for records",
          "parameters": {"limit": 5}
        }
      ]
    }
  ],
  "error_handling": [
    {
      "error": "No refresh token available",
      "solution": [
        {
          "tool": "initiate_oauth_flow",
          "description": "Start new OAuth authentication"
        },
        {
          "tool": "refresh_access_token",
          "description": "Obtain new access tokens"
        }
      ]
    },
    {
      "error": "Device not found",
      "solution": [
        {
          "tool": "list_devices",
          "description": "Verify device exists and get correct ID"
        },
        {
          "tool": "get_device_status",
          "description": "Check device connectivity and status"
        }
      ]
    },
    {
      "error": "API connection failed",
      "solution": [
        {
          "tool": "get_api_status",
          "description": "Check API connectivity status"
        },
        {
          "tool": "refresh_access_token",
          "description": "Refresh authentication if needed"
        }
      ]
    }
  ]
}
